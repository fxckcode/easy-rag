{
  "name": "easy-rag",
  "version": "0.1.0",
  "description": "NestJS template for RAG orchestration with Vercel AI SDK and pgvector",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@ai-sdk/langchain": "^2",
    "@ai-sdk/openai": "^2",
    "@langchain/community": "^1",
    "@langchain/textsplitters": "^1",
    "@nestjs/common": "^11",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11",
    "@nestjs/platform-express": "^11",
    "ai": "^6",
    "pg": "^8",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "zod": "^3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11",
    "@nestjs/testing": "^11",
    "@types/express": "^5",
    "@types/jest": "^29",
    "@types/node": "^22",
    "@types/pg": "^8",
    "@types/supertest": "^6",
    "jest": "^29",
    "source-map-support": "^0.5",
    "supertest": "^7",
    "ts-jest": "^29",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
