# Auto-detect text files and normalize to LF
* text=auto eol=lf

# Binary files — must not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
*.otf binary
*.zip binary
*.tar.gz binary

# Lock files — treat as generated
pnpm-lock.yaml -diff
package-lock.json -diff
yarn.lock -diff

# Test fixtures
*.snapshot -diff
*.snap -diff
